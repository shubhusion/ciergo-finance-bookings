DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Unpooled connection, used for schema push/migrate. On Neon this is the
# non-"-pooler" host (Neon's Vercel integration names it this way); other
# providers may not need a separate one.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Stubbed session. Set to any seeded user id to see the page through their
# permissions. See prisma/seed.ts for the available ids.
#   u-yash   -> ADMIN (default)
#   u-ajay   -> approver for Harshit + Anjali
#   u-rohan  -> plain member, cannot see the approval tab
CURRENT_USER_ID="u-yash"
